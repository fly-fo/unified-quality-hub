{
  "name": "unified-quality-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Unified Quality Hub demo project using Playwright BDD and GitLab CI",
  "scripts": {
    "bddgen": "bddgen",
    "test": "npm run bddgen && playwright test",
    "test:unit": "npm run bddgen && playwright test --grep @unit",
    "test:api": "npm run bddgen && playwright test --grep @api",
    "test:e2e": "npm run bddgen && playwright test --grep @e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.3.0",
    "allure-js-commons": "^3.3.3",
    "allure-playwright": "^3.2.1",
    "playwright": "^1.54.1",
    "playwright-bdd": "^8.4.1",
    "typescript": "^5.9.2"
  }
}