{
    "compilerOptions": {
      "target": "ES2022",
      "module": "CommonJS",
      "moduleResolution": "Node",
      "types": ["node", "@playwright/test"],
      "esModuleInterop": true,
      "strict": false,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "outDir": "dist"
    },
    "include": [
      "playwright.config.ts",
      "steps/**/*.ts",
      "support/**/*.ts"
    ]
  }